universe = vanilla
executable = $(HOME)/y25_fm_sys.sh

# Define parameter values here
dataset = hallusionbench
system_alpha = 0.0
redistribute_to = prop
# Use full or reduced dataset (default = False)
use_reduced = False

# Pass them as arguments to the shell script
arguments = $(dataset) $(system_alpha) $(redistribute_to) $(use_reduced)

# Output files
output = $(HOME)/y25_$(dataset)_fmsys.$(system_alpha).$(redistribute_to).$(use_reduced).$(ClusterId).$(ProcId).txt
error = $(HOME)/y25_$(dataset)_fmsys.$(system_alpha).$(redistribute_to).$(use_reduced).$(ClusterId).$(ProcId).err
log = $(HOME)/y25_$(dataset)_fmsys.$(system_alpha).$(redistribute_to).$(use_reduced).$(ClusterId).$(ProcId).log

request_gpus = 1
request_memory = 25GB
+WantGPULab = true

requirements = (TARGET.Machine == "hopper-1.coli.uni-saarland.de" || \
    TARGET.Machine == "hopper-2.coli.uni-saarland.de" || \
    TARGET.Machine == "hopper-3.coli.uni-saarland.de")

queue
